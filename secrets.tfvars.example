do_token          = "CHANGE_ME_DO_TOKEN"
ovh_endpoint           = "ovh-eu"
ovh_application_key    = "CHANGE_ME_OVH_APPLICATION_KEY"
ovh_application_secret = "CHANGE_ME_OVH_APPLICATION_SECRET"
ovh_consumer_key       = "CHANGE_ME_OVH_CONSUMER_KEY"
velero_access_key = "CHANGE_ME_SPACES_ACCESS"
velero_secret_key = "CHANGE_ME_SPACES_SECRET"
minio_access_key  = "CHANGE_ME_MINIO_ACCESS"
minio_secret_key  = "CHANGE_ME_MINIO_SECRET"

# Postgres
postgres_root_password = "CHANGE_ME_POSTGRES_ROOT"

# MariaDB
mariadb_root_password = "CHANGE_ME_MARIADB_ROOT"

# Analytics (Vince)
analytics_admin_password = "CHANGE_ME_ANALYTICS_ADMIN_PASSWORD"

# Sentry
enable_sentry         = false
sentry_host           = ""
sentry_admin_email    = ""
sentry_admin_password = "CHANGE_ME_SENTRY_ADMIN_PASSWORD"

# OpenCloud
enable_opencloud                 = false
opencloud_host                   = ""
opencloud_admin_password         = "CHANGE_ME_OPENCLOUD_ADMIN_PASSWORD"
opencloud_service_account_id     = "CHANGE_ME_UUID_V4"
opencloud_service_account_secret = "CHANGE_ME_SERVICE_ACCOUNT_SECRET"
opencloud_config_storage_size    = "2Gi"
opencloud_data_storage_size      = "50Gi"
enable_he8us_redirect = false
he8us_redirect_target_url = "https://fullfrontend.be"


# FRP
enable_frp                   = false
frp_host                     = ""
frp_dashboard_host           = ""
frp_additional_http_hosts    = []
frp_dashboard_user           = "admin"
frp_dashboard_password       = "CHANGE_ME_FRP_DASHBOARD_PASSWORD"
frp_auth_token               = "CHANGE_ME_FRP_AUTH_TOKEN"

# Docker Hub (images privées WordPress)
dockerhub_pat   = "CHANGE_ME_DOCKERHUB_PAT"

# Credentials applicatifs (création DB/users au bootstrap des StatefulSets)
# Postgres : n8n, twenty
postgres_app_credentials = [
  {
    name     = "n8n-ffe"
    db_name  = "ffe-automations"
    user     = "ffe-automations"
    password = "CHANGE_ME_N8N_DB_PASSWORD"
  },
  {
    name     = "twenty"
    db_name  = "twenty"
    user     = "twenty"
    password = "CHANGE_ME_TWENTY_DB_PASSWORD"
  },
]

# MariaDB : wordpress
mariadb_app_credentials = [
  {
    name     = "ffe-website"
    db_name  = "ffe-website"
    user     = "ffe-website"
    password = "CHANGE_ME_WP_DB_PASSWORD"
  }
]

# n8n encryption key (N8N_ENCRYPTION_KEY) et queue Redis
n8n_encryption_key    = "CHANGE_ME_N8N_ENCRYPTION_KEY"
n8n_enable_redis      = true
n8n_redis_password    = "CHANGE_ME_REDIS_PASSWORD"

# Twenty
twenty_app_secret = "CHANGE_ME_TWENTY_APP_SECRET"

/*
Registry auth (Zot) - htpasswd (bcrypt)
Login: fullfrontend
Pass: CHANGE_ME_REGISTRY_PASSWORD
*/
registry_htpasswd = "fullfrontend:$2y$05$exampleexampleexampleexampleexa"

# Registry S3 backend
registry_storage_backend = "local" # or "s3"
registry_s3_endpoint     = ""
registry_s3_region       = ""
registry_s3_bucket       = ""
registry_s3_secure       = true
registry_s3_access_key   = ""
registry_s3_secret_key   = ""

acme_email = "CHANGE_ME_ACME_EMAIL"

# WordPress (AS3CF + WP Mail SMTP)
wp_as3_provider   = "do"
wp_as3_access_key = "CHANGE_ME_WP_AS3_ACCESS"
wp_as3_secret_key = "CHANGE_ME_WP_AS3_SECRET"
wp_mail_from      = "CHANGE_ME_WP_MAIL_FROM"
wp_mail_from_name = "CHANGE_ME_WP_MAIL_FROM_NAME"
wp_smtp_host      = "CHANGE_ME_WP_SMTP_HOST"
wp_smtp_port      = "465"
wp_smtp_ssl       = "ssl"
wp_smtp_auth      = true
wp_smtp_user      = "CHANGE_ME_WP_SMTP_USER"
wp_smtp_pass      = "CHANGE_ME_WP_SMTP_PASS"

# SMTP dédié au staging Granges du Tilleul (désactivé par défaut)
grangesdutilleul_stage_wpms_on       = false
grangesdutilleul_stage_mail_from     = ""
grangesdutilleul_stage_mail_from_name = ""
grangesdutilleul_stage_smtp_host     = ""
grangesdutilleul_stage_smtp_port     = "465"
grangesdutilleul_stage_smtp_ssl      = "ssl"
grangesdutilleul_stage_smtp_auth     = true
grangesdutilleul_stage_smtp_user     = ""
grangesdutilleul_stage_smtp_pass     = ""

# Optional app-specific SMTP values (empty = reuse WordPress SMTP values)
n8n_smtp_sender             = ""
n8n_smtp_user               = ""
n8n_smtp_password           = ""
opencloud_smtp_sender       = ""
opencloud_smtp_user         = ""
opencloud_smtp_password     = ""
twenty_email_from_address   = ""
twenty_email_from_name      = ""
twenty_email_system_address = ""
twenty_smtp_user            = ""
twenty_smtp_password        = ""
sentry_mail_from            = ""
sentry_smtp_user            = ""
sentry_smtp_password        = ""

# Grafana admin
grafana_admin_user     = "admin"
grafana_admin_password = "CHANGE_ME_GRAFANA_ADMIN_PASSWORD"
